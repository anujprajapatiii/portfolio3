---
import Layout from '../layouts/Layout.astro';
import Section from '../components/primitives/Section.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const projects = (await getCollection('projects')).sort(
    (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);
---

<Layout title="Your Name — Designer">
    <Section>
        <p class="intro">Designer working across visual identity and digital products. Based in Mumbai.</p>
    </Section>

    <Section>
        <div class="projects">
            {projects.map((project, i) => (
                <a href={`/projects/${project.id}`} class="project-card">
                    <Image
                        src={project.data.cover}
                        alt={`${project.data.title} cover`}
                        widths={[400, 800, 1200]}
                        sizes="(max-width: 640px) 100vw, 400px"
                        loading={i === 0 ? 'eager' : 'lazy'}
                    />
                    <h2>{project.data.title}</h2>
                    <p>{project.data.description}</p>
                </a>
            ))}
        </div>
    </Section>
</Layout>
