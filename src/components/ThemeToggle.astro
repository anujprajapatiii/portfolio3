---
// ThemeToggle — sun/moon button that flips between light and dark themes.
// Pairs with the inline script in Layout.astro that sets the initial theme
// before the page paints (preventing a flash).
//
// Convention: the icon shown is the theme you'll switch TO.
//   Light mode → moon visible (click to go dark)
//   Dark mode  → sun visible  (click to go light)
//
// Icons are from Lucide via astro-icon — see CLAUDE.md → Icons.
import { Icon } from 'astro-icon/components';
---

<button
    id="theme-toggle"
    type="button"
    class="theme-toggle"
    aria-label="Toggle color theme"
    title="Toggle color theme"
>
    <Icon name="lucide:moon" class="icon-moon" aria-hidden="true" />
    <Icon name="lucide:sun"  class="icon-sun"  aria-hidden="true" />
</button>

<script is:inline>
    const button = document.getElementById('theme-toggle');
    button?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';

        const apply = () => {
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
        };

        // View Transitions API gives a clean bitmap crossfade with no
        // per-frame text re-rasterization. Falls back to instant swap
        // on browsers that don't support it (Firefox, older Safari).
        if (document.startViewTransition) {
            document.startViewTransition(apply);
        } else {
            apply();
        }
    });
</script>
