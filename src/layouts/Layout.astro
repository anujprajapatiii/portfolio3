---
import '../styles/global.css';

const { title = 'Your Name — Designer' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
</head>
<body>
    <header>
        <h1><a href="/" style="text-decoration: none; color: inherit;">Your Name</a></h1>
        <nav>
            <a href="/">Work</a>
            <a href="/about">About</a>
        </nav>
    </header>

    <main>
        <slot />
    </main>

    <footer>
        <p>© 2026 Your Name. <a href="mailto:hello@yourname.com">Email</a></p>
    </footer>
</body>
</html>