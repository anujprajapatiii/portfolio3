---
import Layout from '../layouts/Layout.astro';
import Section from '../components/primitives/Section.astro';
import Container from '../components/primitives/Container.astro';
import Stack from '../components/primitives/Stack.astro';
import { SITE_NAME } from '../consts';
---

<Layout title={`Page not found — ${SITE_NAME}`} description="The page you're looking for doesn't exist.">
    <Section size="lg">
        <Container size="page">
            <div class="not-found">
                <Stack gap="md">
                    <h1>404</h1>
                    <p>This page doesn't exist. <a href="/">Go home</a>.</p>
                </Stack>
            </div>
        </Container>
    </Section>
</Layout>
