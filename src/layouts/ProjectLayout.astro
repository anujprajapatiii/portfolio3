---
import Layout from './Layout.astro';
import { Image, getImage } from 'astro:assets';
import PageHeader from '../components/primitives/PageHeader.astro';

const { project } = Astro.props;
const { title, description, cover } = project.data;

// Build a 1200x630 OG image so social previews look right.
const og = await getImage({
    src: cover,
    width: 1200,
    height: 630,
    format: 'webp',
});
---

<Layout
    title={`${title} — Anuj Prajapati`}
    description={description}
    ogImage={og.src}
    ogType="article"
>
    <article class="project-detail">
        <Image
            src={cover}
            alt={`${title} cover`}
            widths={[600, 900, 1200]}
            sizes="(max-width: 768px) calc(100vw - 48px), 720px"
            loading="eager"
            class="project-cover"
        />
        <PageHeader
            title={title}
            description={description}
            class="project-header"
        />
        <div class="project-body">
            <slot />
        </div>
    </article>
</Layout>
