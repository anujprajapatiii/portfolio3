---
// PageHeader — consistent title/intro block for top-level pages and projects.
// Use `description` for plain text, or the default slot for richer content.

interface Props {
    title: string;
    description?: string;
    eyebrow?: string;
    class?: string;
}

const {
    title,
    description,
    eyebrow,
    class: className,
} = Astro.props;
---

<header class:list={['page-header', className]}>
    {eyebrow && <p class="page-header__eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {description && <p class="page-header__description">{description}</p>}
    <slot />
</header>
