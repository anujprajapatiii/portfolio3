---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/primitives/PageHeader.astro';
import Section from '../components/primitives/Section.astro';
import Stack from '../components/primitives/Stack.astro';

// Token data — kept in arrays so we can `.map()` over them below.
// To add a token, add a row here. To rename a token, change it here AND in global.css.

const fontTokens = [
    { name: '--font-display', value: '72px', use: 'hero / landing moments' },
    { name: '--font-xl',      value: '40px', use: 'page heading' },
    { name: '--font-lg',      value: '24px', use: 'in-body heading, homepage intro' },
    { name: '--font-base',    value: '18px', use: 'body' },
    { name: '--font-sm',      value: '16px', use: 'secondary body, card descriptions' },
    { name: '--font-xs',      value: '13px', use: 'fine print, captions' },
];

const leadingTokens = [
    { name: '--leading-display', value: '1.05', use: '40px+' },
    { name: '--leading-tight',   value: '1.3',  use: '22–32px' },
    { name: '--leading-base',    value: '1.5',  use: 'body default' },
    { name: '--leading-loose',   value: '1.6',  use: 'long-form reading' },
];

const trackingTokens = [
    { name: '--tracking-tight', value: '-0.015em', use: 'display sizes' },
];

const spaceTokens = [
    { name: '--space-1', value: '4px' },
    { name: '--space-2', value: '8px' },
    { name: '--space-3', value: '16px' },
    { name: '--space-4', value: '24px' },
    { name: '--space-5', value: '32px' },
    { name: '--space-6', value: '48px' },
    { name: '--space-7', value: '80px' },
    { name: '--space-8', value: '120px' },
];

// Primitive palette — theme-agnostic. Grouped by family.
const primitiveFamilies = [
    {
        name: 'Neutral',
        swatches: [
            { name: 'black', value: '#000000' },
            { name: '900',   value: '#0e0f12' },
            { name: '800',   value: '#141619' },
            { name: '700',   value: '#1c1f24' },
            { name: '600',   value: '#21252b' },
            { name: '500',   value: '#2c323a' },
            { name: '400',   value: '#434b56' },
            { name: '300',   value: '#99a1ac' },
            { name: '200',   value: '#d3d7dd' },
            { name: '100',   value: '#f6f7f8' },
            { name: 'white', value: '#ffffff' },
        ],
    },
    {
        name: 'Blue',
        swatches: [
            { name: '100', value: '#f0f3ff' },
            { name: '200', value: '#dae5ff' },
            { name: '300', value: '#99b6ff' },
            { name: '400', value: '#1e50d3' },
            { name: '500', value: '#1841ac' },
            { name: '600', value: '#002c83' },
        ],
    },
    {
        name: 'Yellow',
        swatches: [
            { name: '100', value: '#fff5f5' },
            { name: '200', value: '#ffe9d0' },
            { name: '300', value: '#ffd293' },
            { name: '400', value: '#ffb700' },
            { name: '500', value: '#d17600' },
            { name: '600', value: '#853e0f' },
        ],
    },
    {
        name: 'Red',
        swatches: [
            { name: '100', value: '#f7a1a2' },
            { name: '200', value: '#f2696a' },
            { name: '300', value: '#ec2426' },
            { name: '400', value: '#67090a' },
        ],
    },
    {
        name: 'Green',
        swatches: [
            { name: '100', value: '#b4e4be' },
            { name: '200', value: '#53c069' },
            { name: '300', value: '#37954a' },
            { name: '400', value: '#1a4723' },
        ],
    },
    {
        name: 'Amber',
        swatches: [
            { name: '100', value: '#f5c2a3' },
            { name: '200', value: '#ee9a68' },
            { name: '300', value: '#e66c24' },
            { name: '400', value: '#7c370e' },
        ],
    },
    {
        name: 'Standard',
        swatches: [
            { name: 'terra', value: '#847b73' },
        ],
    },
];

// Semantic tokens — what the rest of the site actually uses.
// Each maps to a primitive; the L/D columns show which primitive
// is referenced in light vs dark theme.
const colorTokens = [
    { name: '--color-text',    light: 'neutral-600', dark: 'neutral-200', use: 'primary text' },
    { name: '--color-muted',   light: 'neutral-400', dark: 'neutral-300', use: 'secondary text' },
    { name: '--color-bg',      light: 'neutral-100', dark: 'neutral-800', use: 'page background' },
    { name: '--color-border',  light: 'neutral-300', dark: 'neutral-500', use: 'dividers, borders' },
    { name: '--color-surface', light: 'neutral-200', dark: 'neutral-400', use: 'image placeholder' },
    { name: '--color-code-bg', light: 'neutral-200', dark: 'neutral-700', use: 'inline code, code blocks' },
];

const widthTokens = [
    {
        name: '--width-container',
        value: '720px',
        use: 'primary content column',
    },
    {
        name: '--width-page',
        value: 'calc(var(--width-container) + var(--space-4) + var(--space-4))',
        use: 'body shell including side padding',
    },
    {
        name: '--width-reading',
        value: 'var(--width-container)',
        use: 'long-form text column',
    },
    {
        name: '--width-narrow',
        value: 'var(--width-container)',
        use: 'about, intro',
    },
];

const weights = [
    { value: 100, label: 'Thin' },
    { value: 200, label: 'Extra Light' },
    { value: 300, label: 'Light' },
    { value: 400, label: 'Regular' },
    { value: 500, label: 'Medium' },
    { value: 600, label: 'Semi Bold' },
    { value: 700, label: 'Bold' },
    { value: 800, label: 'Extra Bold' },
    { value: 900, label: 'Black' },
];
---

<Layout
    title="Design System — Anuj Prajapati"
    description="A live reference of every design token, type size, color, and spacing value used on this site."
>
    <article class="design-system">
        <Section>
            <PageHeader title="Design system">
                <p>A live preview of every token used on this site. Values below mirror <code>global.css</code> — when changing tokens, update this catalogue alongside the CSS.</p>
            </PageHeader>
        </Section>

        <Section>
            <Stack gap="lg">
                <h2>Typography</h2>

                <Stack gap="md">
                    <h3>Font family</h3>
                    <p style="font-size: var(--font-lg)">TASA Orbiter — variable, weight axis 100–900</p>
                </Stack>

                <Stack gap="md">
                    <h3>Type scale</h3>
                    <Stack gap="md">
                        {fontTokens.map((t) => (
                            <div class="ds-row">
                                <span class="ds-sample" style={`font-size: var(${t.name}); line-height: 1`}>Aa</span>
                                <Stack gap="sm">
                                    <span class="ds-meta">{t.name} · {t.value}</span>
                                    <span class="ds-meta-secondary">{t.use}</span>
                                </Stack>
                            </div>
                        ))}
                    </Stack>
                </Stack>

                <Stack gap="md">
                    <h3>Line height</h3>
                    <Stack gap="md">
                        {leadingTokens.map((t) => (
                            <div class="ds-row">
                                <Stack gap="sm">
                                    <span class="ds-meta">{t.name} · {t.value}</span>
                                    <span class="ds-meta-secondary">{t.use}</span>
                                </Stack>
                            </div>
                        ))}
                    </Stack>
                </Stack>

                <Stack gap="md">
                    <h3>Letter spacing</h3>
                    <Stack gap="md">
                        {trackingTokens.map((t) => (
                            <div class="ds-row">
                                <Stack gap="sm">
                                    <span class="ds-meta">{t.name} · {t.value}</span>
                                    <span class="ds-meta-secondary">{t.use}</span>
                                </Stack>
                            </div>
                        ))}
                    </Stack>
                </Stack>

                <Stack gap="md">
                    <h3>Font weights</h3>
                    <Stack gap="sm">
                        {weights.map((w) => (
                            <p style={`font-weight: ${w.value}; font-size: var(--font-base)`}>
                                {w.value} — {w.label}: The quick brown fox jumps over the lazy dog
                            </p>
                        ))}
                    </Stack>
                </Stack>
            </Stack>
        </Section>

        <Section>
            <Stack gap="lg">
                <h2>Spacing</h2>
                <Stack gap="md">
                    {spaceTokens.map((t) => (
                        <div class="ds-row">
                            <span class="ds-bar" style={`width: var(${t.name})`}></span>
                            <span class="ds-meta">{t.name} · {t.value}</span>
                        </div>
                    ))}
                </Stack>
            </Stack>
        </Section>

        <Section>
            <Stack gap="lg">
                <h2>Primitive colors</h2>
                <p class="ds-meta-secondary">The raw palette. Theme-agnostic — these values don't change between light and dark mode. Semantic tokens below reference these.</p>

                {primitiveFamilies.map((family) => (
                    <Stack gap="md">
                        <h3>{family.name}</h3>
                        <div class="ds-palette">
                            {family.swatches.map((s) => (
                                <div class="ds-palette-cell">
                                    <span class="ds-swatch" style={`background: ${s.value}`}></span>
                                    <span class="ds-meta">{s.name}</span>
                                    <span class="ds-meta-secondary">{s.value}</span>
                                </div>
                            ))}
                        </div>
                    </Stack>
                ))}
            </Stack>
        </Section>

        <Section>
            <Stack gap="lg">
                <h2>Semantic colors</h2>
                <p class="ds-meta-secondary">What the rest of the site actually uses. Each maps to a primitive; the L and D columns show which primitive is referenced in light vs dark theme.</p>
                <Stack gap="md">
                    {colorTokens.map((t) => (
                        <div class="ds-row">
                            <div class="ds-swatch-pair">
                                <span class="ds-swatch" style={`background: var(--${t.light})`} title={`Light: ${t.light}`}></span>
                                <span class="ds-swatch" style={`background: var(--${t.dark})`} title={`Dark: ${t.dark}`}></span>
                            </div>
                            <Stack gap="sm">
                                <span class="ds-meta">{t.name}</span>
                                <span class="ds-meta-secondary">L {t.light} · D {t.dark} · {t.use}</span>
                            </Stack>
                        </div>
                    ))}
                </Stack>
            </Stack>
        </Section>

        <Section>
            <Stack gap="lg">
                <h2>Layout widths</h2>
                <Stack gap="md">
                    {widthTokens.map((t) => (
                        <div class="ds-row">
                            <Stack gap="sm">
                                <span class="ds-meta">{t.name} · {t.value}</span>
                                <span class="ds-meta-secondary">{t.use}</span>
                            </Stack>
                        </div>
                    ))}
                </Stack>
            </Stack>
        </Section>
    </article>
</Layout>
