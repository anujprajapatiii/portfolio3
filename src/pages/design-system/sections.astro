---
import { Code } from 'astro:components';
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/primitives/Section.astro';
import Container from '../../components/primitives/Container.astro';
import Stack from '../../components/primitives/Stack.astro';
import { sections, categories, categoryLabel, sectionsByCategory } from '../../lib/sections';
---

<Layout
    title="Sections — Design System"
    description="Ready-to-paste section templates used across this portfolio. Browse by category, copy a snippet, drop it into a page, change the content."
>
    <article class="design-system sections-gallery">
        <Section size="lg">
            <Container size="page">
                <Stack gap="lg">
                    <h1>Sections gallery</h1>
                    <p>
                        Ready-to-paste section templates, organised by category. Each card shows a
                        live preview and the snippet that produced it. Copy the snippet, paste into
                        a page, change the content.
                    </p>
                    <p>Back to <a href="/design-system">tokens &amp; primitives</a>.</p>
                </Stack>
            </Container>
        </Section>

        <Section size="lg">
            <Container size="page">
                <div class="sections-layout">
                    <aside class="sections-rail" aria-label="Sections by category">
                        <p class="sections-rail-eyebrow">{sections.length} sections</p>
                        <ul class="sections-rail-list">
                            {
                                categories.map((c) => (
                                    <li>
                                        <a href={`#${c}`} class="sections-rail-link">
                                            <span>{categoryLabel(c)}</span>
                                            <span class="sections-rail-count">
                                                {sectionsByCategory(c).length}
                                            </span>
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </aside>

                    <div class="sections-main">
                        {
                            categories.map((c) => (
                                <section class="sections-group" id={c}>
                                    <header class="sections-group-header">
                                        <h2>{categoryLabel(c)}</h2>
                                        <p class="sections-group-count">
                                            {sectionsByCategory(c).length} section
                                            {sectionsByCategory(c).length === 1 ? '' : 's'}
                                        </p>
                                    </header>

                                    <Stack gap="lg">
                                        {sectionsByCategory(c).map((entry) => {
                                            const Preview = entry.Component;
                                            return (
                                                <article class="section-card" id={entry.slug}>
                                                    <header class="section-card-header">
                                                        <h3>{entry.name}</h3>
                                                        <p class="ds-meta-secondary">{entry.use}</p>
                                                    </header>

                                                    <div class="section-card-preview">
                                                        <Preview />
                                                    </div>

                                                    <div class="section-card-snippet">
                                                        <button
                                                            type="button"
                                                            class="section-copy"
                                                            data-section-copy={entry.source}
                                                            aria-label={`Copy ${entry.name} snippet`}
                                                        >
                                                            Copy
                                                        </button>
                                                        <Code
                                                            lang="astro"
                                                            code={entry.source}
                                                            wrap
                                                        />
                                                    </div>
                                                </article>
                                            );
                                        })}
                                    </Stack>
                                </section>
                            ))
                        }
                    </div>
                </div>
            </Container>
        </Section>
    </article>

    <script>
        // Single delegated listener — every Copy button stores its snippet
        // on a `data-section-copy` attribute. No per-button JS, no client
        // islands, no extra bundles.
        function flashCopied(button: HTMLButtonElement) {
            const original = button.textContent;
            button.textContent = 'Copied';
            button.classList.add('section-copy--copied');
            window.setTimeout(() => {
                button.textContent = original;
                button.classList.remove('section-copy--copied');
            }, 1400);
        }

        function legacyCopy(text: string): boolean {
            // Fallback when navigator.clipboard isn't available or is denied
            // (insecure context, headless browsers without permission, older
            // Safari). A hidden textarea + execCommand works everywhere.
            const textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.setAttribute('readonly', '');
            textarea.style.position = 'fixed';
            textarea.style.opacity = '0';
            textarea.style.pointerEvents = 'none';
            document.body.appendChild(textarea);
            textarea.select();
            let ok = false;
            try {
                ok = document.execCommand('copy');
            } catch {
                ok = false;
            }
            document.body.removeChild(textarea);
            return ok;
        }

        document.addEventListener('click', async (event) => {
            const target = event.target as HTMLElement;
            const button = target.closest<HTMLButtonElement>('[data-section-copy]');
            if (!button) return;
            const source = button.dataset.sectionCopy ?? '';

            if (navigator.clipboard?.writeText) {
                try {
                    await navigator.clipboard.writeText(source);
                    flashCopied(button);
                    return;
                } catch {
                    // fall through to legacy path
                }
            }
            if (legacyCopy(source)) {
                flashCopied(button);
            } else {
                button.textContent = 'Copy failed';
            }
        });
    </script>
</Layout>

<style>
    /* Page-scoped layout for the rail + main column.
       This grid is specific to the sections gallery — not a shared layout
       primitive — so it lives here rather than in global.css. */
    .sections-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-6);
        align-items: start;
    }

    @media (min-width: 768px) {
        .sections-layout {
            grid-template-columns: 12rem 1fr;
            gap: var(--space-7);
        }
    }

    /* Sticky rail. Hidden below the md breakpoint — narrow viewports get the
       inline category headings as their navigation, jump-links still work.
       Top offset clears the sticky site header (~59px) with breathing room. */
    .sections-rail {
        display: none;
    }

    @media (min-width: 768px) {
        .sections-rail {
            display: block;
            position: sticky;
            top: var(--space-7);
            align-self: start;
        }
    }

    .sections-rail-eyebrow {
        font-size: var(--font-xs);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-muted);
        margin: 0 0 var(--space-3);
    }

    .sections-rail-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .sections-rail-link {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: var(--space-3);
        padding: var(--space-2) 0;
        color: var(--color-text);
        text-decoration: none;
        font-size: var(--font-sm);
        border-bottom: 1px solid transparent;
        transition: border-color 120ms ease;
    }

    .sections-rail-link:hover {
        border-bottom-color: var(--color-border);
    }

    .sections-rail-count {
        font-variant-numeric: tabular-nums;
        color: var(--color-muted);
        font-size: var(--font-xs);
    }

    .sections-main {
        display: flex;
        flex-direction: column;
        gap: var(--space-7);
        min-width: 0; /* let inner Code blocks wrap rather than expand the grid */
    }

    .sections-group {
        scroll-margin-top: var(--space-7);
    }

    .sections-group-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: var(--space-3);
        border-bottom: 1px solid var(--color-border);
        padding-bottom: var(--space-3);
        margin-bottom: var(--space-5);
    }

    .sections-group-header h2 {
        margin: 0;
    }

    .sections-group-count {
        margin: 0;
        font-size: var(--font-sm);
        color: var(--color-muted);
        font-variant-numeric: tabular-nums;
    }

    /* A single section card: heading + preview + snippet. */
    .section-card {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
        scroll-margin-top: var(--space-7);
    }

    .section-card-header h3 {
        margin: 0 0 var(--space-1);
        font-size: var(--font-lg);
    }

    /* Frame around each preview. The preview's own Section/Container provides
       the inner padding — the frame just gives a visible boundary. */
    .section-card-preview {
        border: 1px solid var(--color-border);
        border-radius: 4px;
        overflow: hidden;
        background: var(--color-bg);
    }

    /* The preview is rendered inside a card, not a real page. Cancel the
       page-padding inheritance from PageWrapper so previews show edge-to-edge
       within the frame. (PageWrapper sets padding-inline at the <main> level
       — here we're nested below that already, so nothing extra to override.) */

    .section-card-snippet {
        position: relative;
    }

    .section-copy {
        position: absolute;
        top: var(--space-2);
        right: var(--space-2);
        z-index: 1;
        font: inherit;
        font-size: var(--font-xs);
        padding: var(--space-1) var(--space-2);
        border: 1px solid var(--color-border);
        background: var(--color-bg);
        color: var(--color-text);
        border-radius: 4px;
        cursor: pointer;
        transition: background 120ms ease;
    }

    .section-copy:hover {
        background: var(--color-surface);
    }

    .section-copy--copied {
        background: var(--color-text);
        color: var(--color-bg);
        border-color: var(--color-text);
    }
</style>
