---
import Layout from './Layout.astro';
import Section from '../components/primitives/Section.astro';
import Container from '../components/primitives/Container.astro';
import Stack from '../components/primitives/Stack.astro';
import { Image, getImage } from 'astro:assets';

const { project } = Astro.props;
const { title, description, cover } = project.data;

// Build a 1200x630 OG image so social previews look right.
const og = await getImage({
    src: cover,
    width: 1200,
    height: 630,
    format: 'webp',
});
---

<Layout
    title={`${title} — Your Name`}
    description={description}
    ogImage={og.src}
    ogType="article"
>
    <article>
        <Section size="lg">
            <Container size="page">
                <Stack gap="lg">
                    <Image
                        src={cover}
                        alt={`${title} cover`}
                        widths={[600, 1200, 1800]}
                        sizes="(max-width: 880px) 100vw, 832px"
                        loading="eager"
                        class="project-cover"
                    />
                    <Stack gap="sm">
                        <h1 class="project-title">{title}</h1>
                        <p class="project-description">{description}</p>
                    </Stack>
                </Stack>
            </Container>
        </Section>

        <Section size="lg">
            <Container size="page">
                <div class="project-body">
                    <slot />
                </div>
            </Container>
        </Section>
    </article>
</Layout>
