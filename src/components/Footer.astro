---
// Site footer — three columns of links (Projects / Playground / Site) plus
// a small copyright line. Auto-pulls projects from the content collection
// so a new case study appears in the footer without editing this file.
//
// To add a new link: edit the appropriate column's `links` array below.
// To add a new column: append { title, links } to the `columns` array.
// To repopulate Playground later: drop entries into its `links` array.

import { getCollection } from 'astro:content';
import PageWrapper from './primitives/PageWrapper.astro';
import Section from './primitives/Section.astro';
import Container from './primitives/Container.astro';
import Stack from './primitives/Stack.astro';
import Grid from './primitives/Grid.astro';

const projects = (await getCollection('projects', (p) => !p.data.draft)).sort(
    (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

const columns = [
    {
        title: 'Projects',
        links: projects.map((p) => ({
            label: p.data.title,
            href: `/projects/${p.id}`,
        })),
    },
    {
        title: 'Playground',
        links: [],
    },
    {
        title: 'Site',
        links: [
            { label: 'Design system', href: '/design-system' },
            { label: 'Sections', href: '/design-system/sections' },
        ],
    },
];
---

<footer>
    <PageWrapper>
        <Section size="md">
            <Container size="page">
                <Grid min="220px" gap="lg">
                    {
                        columns.map((col) => (
                            <Stack gap="sm">
                                <h3 class="footer-col-title">{col.title}</h3>
                                <hr class="footer-rule" />
                                <div class="footer-col-list">
                                    {col.links.length === 0 ? (
                                        <span class="footer-col-empty">—</span>
                                    ) : (
                                        col.links.map((link) => (
                                            <a class="footer-link" href={link.href}>
                                                {link.label}
                                            </a>
                                        ))
                                    )}
                                </div>
                            </Stack>
                        ))
                    }
                </Grid>
                <p class="footer-meta">© 2026 Your Name</p>
            </Container>
        </Section>
    </PageWrapper>
</footer>
