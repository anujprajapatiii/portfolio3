---
// Site footer — three columns of links (Projects / Play / Site) plus a
// small copyright line. Auto-pulls projects and experiments from their
// content collections so new entries appear in the footer without editing
// this file.
//
// To add a new link: edit the appropriate column's `links` array below.
// To add a new column: append { title, links } to the `columns` array.
//
// Note: a hand-crafted /play/<slug>.astro page that should appear in the
// footer also needs a stub entry in src/content/experiments/<slug>.md —
// the markdown supplies listing metadata; the .astro file wins at the URL.

import { getCollection } from 'astro:content';
import PageWrapper from './primitives/PageWrapper.astro';
import Section from './primitives/Section.astro';
import Container from './primitives/Container.astro';
import Stack from './primitives/Stack.astro';
import Grid from './primitives/Grid.astro';

const projects = (await getCollection('projects', (p) => !p.data.draft)).sort(
    (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

const experiments = (await getCollection('experiments', (e) => !e.data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const columns = [
    {
        title: 'Projects',
        links: projects.map((p) => ({
            label: p.data.title,
            href: `/projects/${p.id}`,
        })),
    },
    {
        title: 'Play',
        links: experiments.map((e) => ({
            label: e.data.title,
            href: `/play/${e.id}`,
        })),
    },
    {
        title: 'Reference',
        links: [
            { label: 'Reference', href: '/reference' },
            { label: 'Sections', href: '/reference/sections' },
        ],
    },
];
---

<footer>
    <PageWrapper>
        <Section size="md">
            <Container size="page">
                <Grid min="220px" gap="lg">
                    {
                        columns.map((col) => (
                            <Stack gap="sm">
                                <h3 class="footer-col-title">{col.title}</h3>
                                <hr class="footer-rule" />
                                <div class="footer-col-list">
                                    {col.links.length === 0 ? (
                                        <span class="footer-col-empty">—</span>
                                    ) : (
                                        col.links.map((link) => (
                                            <a class="footer-link" href={link.href}>
                                                {link.label}
                                            </a>
                                        ))
                                    )}
                                </div>
                            </Stack>
                        ))
                    }
                </Grid>
                <p class="footer-meta">© 2026 Your Name</p>
            </Container>
        </Section>
    </PageWrapper>
</footer>
