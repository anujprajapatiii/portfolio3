---
// /reference — single design-system page covering tokens AND layout
// primitives together. Tokens are the values; primitives are the
// components that consume them. They reference each other constantly and
// reading them on the same page reflects how they're actually used.
//
// If a new internal-docs topic is genuinely different in shape (e.g. the
// section gallery at /reference/sections), it gets its own page.

import Layout from '../../layouts/Layout.astro';
import Section from '../../components/primitives/Section.astro';
import Container from '../../components/primitives/Container.astro';
import Stack from '../../components/primitives/Stack.astro';
import Cluster from '../../components/primitives/Cluster.astro';
import Grid from '../../components/primitives/Grid.astro';
import { SITE_NAME } from '../../consts';

// Token data — kept in arrays so we can `.map()` over them below.
// To add a token, add a row here. To rename a token, change it here AND in global.css.

const fontTokens = [
    { name: '--font-display', value: '72px', use: 'hero / landing moments' },
    { name: '--font-xl', value: '40px', use: 'page heading' },
    { name: '--font-lg', value: '24px', use: 'in-body heading, homepage intro' },
    { name: '--font-base', value: '18px', use: 'body' },
    { name: '--font-sm', value: '16px', use: 'secondary body, card descriptions' },
    { name: '--font-xs', value: '13px', use: 'fine print, captions' },
];

const leadingTokens = [
    { name: '--leading-display', value: '1.05', use: '40px+' },
    { name: '--leading-tight', value: '1.3', use: '22–32px' },
    { name: '--leading-base', value: '1.5', use: 'body default' },
    { name: '--leading-loose', value: '1.6', use: 'long-form reading' },
];

const trackingTokens = [{ name: '--tracking-tight', value: '-0.015em', use: 'display sizes' }];

const spaceTokens = [
    { name: '--space-1', value: '4px' },
    { name: '--space-2', value: '8px' },
    { name: '--space-3', value: '16px' },
    { name: '--space-4', value: '24px' },
    { name: '--space-5', value: '32px' },
    { name: '--space-6', value: '48px' },
    { name: '--space-7', value: '80px' },
    { name: '--space-8', value: '120px' },
];

const primitiveFamilies = [
    {
        name: 'Neutral',
        swatches: [
            { name: 'black', value: '#000000' },
            { name: '900', value: '#0e0f12' },
            { name: '800', value: '#141619' },
            { name: '700', value: '#1c1f24' },
            { name: '600', value: '#21252b' },
            { name: '500', value: '#2c323a' },
            { name: '400', value: '#434b56' },
            { name: '300', value: '#99a1ac' },
            { name: '200', value: '#d3d7dd' },
            { name: '100', value: '#f6f7f8' },
            { name: 'white', value: '#ffffff' },
        ],
    },
    {
        name: 'Blue',
        swatches: [
            { name: '100', value: '#f0f3ff' },
            { name: '200', value: '#dae5ff' },
            { name: '300', value: '#99b6ff' },
            { name: '400', value: '#1e50d3' },
            { name: '500', value: '#1841ac' },
            { name: '600', value: '#002c83' },
        ],
    },
    {
        name: 'Yellow',
        swatches: [
            { name: '100', value: '#fff5f5' },
            { name: '200', value: '#ffe9d0' },
            { name: '300', value: '#ffd293' },
            { name: '400', value: '#ffb700' },
            { name: '500', value: '#d17600' },
            { name: '600', value: '#853e0f' },
        ],
    },
    {
        name: 'Red',
        swatches: [
            { name: '100', value: '#f7a1a2' },
            { name: '200', value: '#f2696a' },
            { name: '300', value: '#ec2426' },
            { name: '400', value: '#67090a' },
        ],
    },
    {
        name: 'Green',
        swatches: [
            { name: '100', value: '#b4e4be' },
            { name: '200', value: '#53c069' },
            { name: '300', value: '#37954a' },
            { name: '400', value: '#1a4723' },
        ],
    },
    {
        name: 'Amber',
        swatches: [
            { name: '100', value: '#f5c2a3' },
            { name: '200', value: '#ee9a68' },
            { name: '300', value: '#e66c24' },
            { name: '400', value: '#7c370e' },
        ],
    },
    {
        name: 'Standard',
        swatches: [{ name: 'terra', value: '#847b73' }],
    },
];

const colorTokens = [
    { name: '--color-text', light: 'neutral-600', dark: 'neutral-200', use: 'primary text' },
    { name: '--color-muted', light: 'neutral-400', dark: 'neutral-300', use: 'secondary text' },
    { name: '--color-bg', light: 'neutral-100', dark: 'neutral-800', use: 'page background' },
    { name: '--color-border', light: 'neutral-300', dark: 'neutral-500', use: 'dividers, borders' },
    {
        name: '--color-surface',
        light: 'neutral-200',
        dark: 'neutral-400',
        use: 'image placeholder',
    },
    {
        name: '--color-code-bg',
        light: 'neutral-200',
        dark: 'neutral-700',
        use: 'inline code, code blocks',
    },
];

const widthTokens = [
    { name: '--width-page', value: '880px', use: 'outer page container' },
    { name: '--width-reading', value: '680px', use: 'long-form text column' },
    { name: '--width-narrow', value: '600px', use: 'about, intro' },
];

const breakpointTokens = [
    { name: '--bp-sm', value: '480px', use: 'small mobile → larger mobile' },
    { name: '--bp-md', value: '768px', use: 'mobile → tablet (primary split)' },
    { name: '--bp-lg', value: '1024px', use: 'tablet → laptop' },
    { name: '--bp-xl', value: '1280px', use: 'laptop → desktop' },
];

const layoutPrimitives = [
    {
        name: '<PageWrapper>',
        props: 'no props',
        use: 'horizontal page padding (24px mobile, 32px tablet+). Used by header, main, footer.',
    },
    {
        name: '<Section size>',
        props: 'size: sm | md | lg | xl',
        use: 'vertical chunk of a page. padding-block per size. Default md.',
    },
    {
        name: '<Container size>',
        props: 'size: page | reading | narrow',
        use: 'max-width + center. Inside Section. Default page.',
    },
    {
        name: '<Stack gap>',
        props: 'gap: sm | md | lg',
        use: 'vertical flex with gap. Default md.',
    },
    {
        name: '<Cluster gap align justify as>',
        props: 'gap, align, justify, as',
        use: 'horizontal flex with wrap. For nav, tag rows.',
    },
    {
        name: '<Grid min gap>',
        props: 'min: 220px | 280px | 360px; gap: md | lg',
        use: 'auto-fit responsive grid. No media query needed.',
    },
];

const sectionSizes = [
    { size: 'sm', value: '32px', use: 'tight related blocks' },
    { size: 'md', value: '48px', use: 'default' },
    { size: 'lg', value: '80px', use: 'distinct page chapters' },
    { size: 'xl', value: '120px', use: 'hero / landing' },
];

const weights = [
    { value: 100, label: 'Thin' },
    { value: 200, label: 'Extra Light' },
    { value: 300, label: 'Light' },
    { value: 400, label: 'Regular' },
    { value: 500, label: 'Medium' },
    { value: 600, label: 'Semi Bold' },
    { value: 700, label: 'Bold' },
    { value: 800, label: 'Extra Bold' },
    { value: 900, label: 'Black' },
];
---

<Layout
    title={`Reference — ${SITE_NAME}`}
    description="A live reference of every design token, layout primitive, and section template used on this site."
>
    <article class="design-system">
        <Section size="lg">
            <Container size="page">
                <Stack gap="lg">
                    <h1>Reference</h1>
                    <p>
                        A live preview of every token, primitive, and rule that builds this site.
                        Values are pulled directly from <code>global.css</code> — change a token there
                        and this page updates.
                    </p>
                    <p>
                        Looking for ready-to-paste section templates? See <a
                            href="/reference/sections">Sections</a
                        >.
                    </p>
                </Stack>
            </Container>
        </Section>

        <Section size="lg">
            <Container size="page">
                <Stack gap="lg">
                    <h2>Layout primitives</h2>
                    <p class="ds-meta-secondary">
                        Every page composes from these. See <code
                            >.claude/skills/portfolio-layout-primitives/SKILL.md</code
                        > for the rules.
                    </p>

                    <Stack gap="md">
                        <h3>Composition rule</h3>
                        <pre
                            class="ds-code">PageWrapper
└─ Section size="sm|md|lg|xl"
   └─ Container size="page|reading|narrow"
      └─ Stack | Grid | Cluster
         └─ content</pre>
                    </Stack>

                    <Stack gap="md">
                        <h3>Primitives</h3>
                        <Stack gap="sm">
                            {
                                layoutPrimitives.map((p) => (
                                    <div class="ds-row">
                                        <Stack gap="sm">
                                            <span class="ds-meta">{p.name}</span>
                                            <span class="ds-meta-secondary">
                                                <code>{p.props}</code> · {p.use}
                                            </span>
                                        </Stack>
                                    </div>
                                ))
                            }
                        </Stack>
                    </Stack>

                    <Stack gap="md">
                        <h3>Section sizes</h3>
                        <p class="ds-meta-secondary">
                            padding-block per size. Bars show the actual top-or-bottom padding
                            height.
                        </p>
                        <Stack gap="md">
                            {
                                sectionSizes.map((s) => (
                                    <div class="ds-row">
                                        <span class="ds-section-bar" style={`height: ${s.value}`} />
                                        <Stack gap="sm">
                                            <span class="ds-meta">
                                                size="{s.size}" · {s.value}
                                            </span>
                                            <span class="ds-meta-secondary">{s.use}</span>
                                        </Stack>
                                    </div>
                                ))
                            }
                        </Stack>
                    </Stack>

                    <Stack gap="md">
                        <h3>Container sizes</h3>
                        <p class="ds-meta-secondary">
                            Visual stack of the three max-widths. The page container wraps the
                            others for comparison.
                        </p>
                        <div class="ds-container-demo ds-container-demo--page">
                            <span class="ds-meta">page · 880px</span>
                            <div class="ds-container-demo ds-container-demo--reading">
                                <span class="ds-meta">reading · 680px</span>
                                <div class="ds-container-demo ds-container-demo--narrow">
                                    <span class="ds-meta">narrow · 600px</span>
                                </div>
                            </div>
                        </div>
                    </Stack>

                    <Stack gap="md">
                        <h3>Grid demo</h3>
                        <p class="ds-meta-secondary">
                            Resize the window — columns auto-fit at 220px minimum.
                        </p>
                        <Grid min="220px" gap="md">
                            <div class="ds-grid-cell">1</div>
                            <div class="ds-grid-cell">2</div>
                            <div class="ds-grid-cell">3</div>
                            <div class="ds-grid-cell">4</div>
                            <div class="ds-grid-cell">5</div>
                            <div class="ds-grid-cell">6</div>
                        </Grid>
                    </Stack>

                    <Stack gap="md">
                        <h3>Cluster demo</h3>
                        <p class="ds-meta-secondary">Horizontal items with wrap.</p>
                        <Cluster gap="md">
                            <span class="ds-tag">item one</span>
                            <span class="ds-tag">item two</span>
                            <span class="ds-tag">item three</span>
                            <span class="ds-tag">item four</span>
                            <span class="ds-tag">item five</span>
                        </Cluster>
                    </Stack>
                </Stack>
            </Container>
        </Section>

        <Section size="lg">
            <Container size="page">
                <Stack gap="lg">
                    <h2>Breakpoints</h2>
                    <p class="ds-meta-secondary">
                        CSS custom properties don't work inside <code>@media</code> queries — these tokens
                        document the values used in <code>@media</code> rules. Keep in sync.
                    </p>
                    <Stack gap="md">
                        {
                            breakpointTokens.map((t) => (
                                <div class="ds-row">
                                    <Stack gap="sm">
                                        <span class="ds-meta">
                                            {t.name} · {t.value}
                                        </span>
                                        <span class="ds-meta-secondary">{t.use}</span>
                                    </Stack>
                                </div>
                            ))
                        }
                    </Stack>
                </Stack>
            </Container>
        </Section>

        <Section size="lg">
            <Container size="page">
                <Stack gap="lg">
                    <h2>Typography</h2>

                    <Stack gap="md">
                        <h3>Font family</h3>
                        <p style="font-size: var(--font-lg)">
                            TASA Orbiter — variable, weight axis 100–900
                        </p>
                    </Stack>

                    <Stack gap="md">
                        <h3>Type scale</h3>
                        <Stack gap="md">
                            {
                                fontTokens.map((t) => (
                                    <div class="ds-row">
                                        <span
                                            class="ds-sample"
                                            style={`font-size: var(${t.name}); line-height: 1`}
                                        >
                                            Aa
                                        </span>
                                        <Stack gap="sm">
                                            <span class="ds-meta">
                                                {t.name} · {t.value}
                                            </span>
                                            <span class="ds-meta-secondary">{t.use}</span>
                                        </Stack>
                                    </div>
                                ))
                            }
                        </Stack>
                    </Stack>

                    <Stack gap="md">
                        <h3>Line height</h3>
                        <Stack gap="md">
                            {
                                leadingTokens.map((t) => (
                                    <div class="ds-row">
                                        <Stack gap="sm">
                                            <span class="ds-meta">
                                                {t.name} · {t.value}
                                            </span>
                                            <span class="ds-meta-secondary">{t.use}</span>
                                        </Stack>
                                    </div>
                                ))
                            }
                        </Stack>
                    </Stack>

                    <Stack gap="md">
                        <h3>Letter spacing</h3>
                        <Stack gap="md">
                            {
                                trackingTokens.map((t) => (
                                    <div class="ds-row">
                                        <Stack gap="sm">
                                            <span class="ds-meta">
                                                {t.name} · {t.value}
                                            </span>
                                            <span class="ds-meta-secondary">{t.use}</span>
                                        </Stack>
                                    </div>
                                ))
                            }
                        </Stack>
                    </Stack>

                    <Stack gap="md">
                        <h3>Font weights</h3>
                        <Stack gap="sm">
                            {
                                weights.map((w) => (
                                    <p
                                        style={`font-weight: ${w.value}; font-size: var(--font-base)`}
                                    >
                                        {w.value} — {w.label}: The quick brown fox jumps over the
                                        lazy dog
                                    </p>
                                ))
                            }
                        </Stack>
                    </Stack>
                </Stack>
            </Container>
        </Section>

        <Section size="lg">
            <Container size="page">
                <Stack gap="lg">
                    <h2>Spacing</h2>
                    <Stack gap="md">
                        {
                            spaceTokens.map((t) => (
                                <div class="ds-row">
                                    <span class="ds-bar" style={`width: var(${t.name})`} />
                                    <span class="ds-meta">
                                        {t.name} · {t.value}
                                    </span>
                                </div>
                            ))
                        }
                    </Stack>
                </Stack>
            </Container>
        </Section>

        <Section size="lg">
            <Container size="page">
                <Stack gap="lg">
                    <h2>Primitive colors</h2>
                    <p class="ds-meta-secondary">
                        The raw palette. Theme-agnostic — these values don't change between light
                        and dark mode. Semantic tokens below reference these.
                    </p>

                    {
                        primitiveFamilies.map((family) => (
                            <Stack gap="md">
                                <h3>{family.name}</h3>
                                <div class="ds-palette">
                                    {family.swatches.map((s) => (
                                        <div class="ds-palette-cell">
                                            <span
                                                class="ds-swatch"
                                                style={`background: ${s.value}`}
                                            />
                                            <span class="ds-meta">{s.name}</span>
                                            <span class="ds-meta-secondary">{s.value}</span>
                                        </div>
                                    ))}
                                </div>
                            </Stack>
                        ))
                    }
                </Stack>
            </Container>
        </Section>

        <Section size="lg">
            <Container size="page">
                <Stack gap="lg">
                    <h2>Semantic colors</h2>
                    <p class="ds-meta-secondary">
                        What the rest of the site actually uses. Each maps to a primitive; the L and
                        D columns show which primitive is referenced in light vs dark theme.
                    </p>
                    <Stack gap="md">
                        {
                            colorTokens.map((t) => (
                                <div class="ds-row">
                                    <div class="ds-swatch-pair">
                                        <span
                                            class="ds-swatch"
                                            style={`background: var(--${t.light})`}
                                            title={`Light: ${t.light}`}
                                        />
                                        <span
                                            class="ds-swatch"
                                            style={`background: var(--${t.dark})`}
                                            title={`Dark: ${t.dark}`}
                                        />
                                    </div>
                                    <Stack gap="sm">
                                        <span class="ds-meta">{t.name}</span>
                                        <span class="ds-meta-secondary">
                                            L {t.light} · D {t.dark} · {t.use}
                                        </span>
                                    </Stack>
                                </div>
                            ))
                        }
                    </Stack>
                </Stack>
            </Container>
        </Section>

        <Section size="lg">
            <Container size="page">
                <Stack gap="lg">
                    <h2>Layout widths</h2>
                    <Stack gap="md">
                        {
                            widthTokens.map((t) => (
                                <div class="ds-row">
                                    <Stack gap="sm">
                                        <span class="ds-meta">
                                            {t.name} · {t.value}
                                        </span>
                                        <span class="ds-meta-secondary">{t.use}</span>
                                    </Stack>
                                </div>
                            ))
                        }
                    </Stack>
                </Stack>
            </Container>
        </Section>
    </article>
</Layout>
