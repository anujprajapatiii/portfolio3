---
// Demo wrapper for Stack — provides example children so the story
// renders something visible. Used only by Stack.stories.ts.

import Stack from './Stack.astro';

interface Props {
    gap?: 'sm' | 'md' | 'lg';
}

const { gap = 'md' } = Astro.props;
---

<Stack gap={gap}>
    <p>The first item in the stack.</p>
    <p>The second item, separated by the configured gap.</p>
    <p>The third item — you can drop in as many children as you like.</p>
    <p>Each child gets the same vertical spacing from its neighbors.</p>
</Stack>
