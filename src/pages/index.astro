---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const projects = (await getCollection('projects')).sort(
    (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);
---

<Layout title="Your Name — Designer">
    <section class="intro">
        <p>Designer working across visual identity and digital products. Based in Mumbai.</p>
    </section>

    <section class="projects">
        {projects.map((project) => (
            <a href={`/projects/${project.id}`} class="project-card">
                <Image src={project.data.cover} alt={`${project.data.title} cover`} widths={[400, 800, 1200]} sizes="(max-width: 640px) 100vw, 400px" />
                <h2>{project.data.title}</h2>
                <p>{project.data.description}</p>
            </a>
        ))}
    </section>
</Layout>