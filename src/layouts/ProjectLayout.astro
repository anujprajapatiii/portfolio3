---
import Layout from './Layout.astro';
import { Image, getImage } from 'astro:assets';

const { project } = Astro.props;
const { title, description, cover } = project.data;

// Build a 1200x630 OG image so social previews look right.
const og = await getImage({
    src: cover,
    width: 1200,
    height: 630,
    format: 'webp',
});
---

<Layout
    title={`${title} — Your Name`}
    description={description}
    ogImage={og.src}
    ogType="article"
>
    <article>
        <Image
            src={cover}
            alt={`${title} cover`}
            widths={[600, 1200, 1800]}
            sizes="(max-width: 880px) 100vw, 832px"
            loading="eager"
            class="project-cover"
        />
        <h1 class="project-title">{title}</h1>
        <p class="project-description">{description}</p>
        <div class="project-body">
            <slot />
        </div>
    </article>
</Layout>
